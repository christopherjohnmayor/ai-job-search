# Add TinyTeX + bun to PATH for this project
export TINYTEX_HOME="$HOME/.TinyTeX"
case ":$PATH:" in
  *":$TINYTEX_HOME/bin/x86_64-linux:"*) ;;
  *) export PATH="$TINYTEX_HOME/bin/x86_64-linux:$PATH" ;;
esac
case ":$PATH:" in
  *":/home/christopher/.bun/bin:"*) ;;
  *) export PATH="/home/christopher/.bun/bin:$PATH" ;;
esac
